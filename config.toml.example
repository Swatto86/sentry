[api]
# ── Option A (default): OpenRouter — free models, no Claude usage ──────────────
# Lowest-cost option. The `openrouter/free` meta-model auto-routes to a current
# free model, so you don't have to track model names. Add your OpenRouter key in
# the app's Settings panel (or here) — everything else is editable in Settings,
# no need to touch this file. Get a key at https://openrouter.ai/keys
provider = "openrouter"
openrouter_api_key = ""   # required — paste your sk-or-v1-... key (or set it in Settings)
model = "openrouter/free" # auto-routes to a free model; or pin one from https://openrouter.ai/models

# Model for the on-demand "Other Updates" app check (which uses live web search).
# It follows your main provider: OpenRouter uses the main model + OpenRouter's web
# plugin; Claude CLI uses this model (blank = haiku). For OpenRouter this field is
# ignored. Editable in Settings.
update_check_model = "haiku"

# ── Option B: Claude CLI (no API key — uses your logged-in `claude` session) ──
# The service runs as LocalSystem. Leave user_profile and claude_cli_path blank
# and it auto-detects: it scans C:\Users for the profile that holds a logged-in
# Claude session (~/.claude/.credentials.json) and finds claude.exe under it.
# provider = "claude_cli"
# user_profile = "C:\\Users\\YourName"
# claude_cli_path = "C:\\Users\\YourName\\.local\\bin\\claude.exe"
# model = ""   # leave empty to use the CLI's configured default, or e.g. "sonnet" / "claude-opus-4-8"
# effort = ""  # Claude CLI reasoning effort: low|medium|high|xhigh|max (blank = CLI default)

# ── Option C: Anthropic native API ────────────────────────────────────────────
# provider = "anthropic"
# anthropic_api_key = "sk-ant-..."
# model = "claude-opus-4-8"

# ── Option D: claude-max-api-proxy (OpenAI-compatible local proxy) ────────────
# Run first: npx claude-max-api-proxy
# provider = "openai_compatible"
# base_url = "http://localhost:3456/v1"
# api_key = "not-needed"
# model = "claude-opus-4-8"

[monitoring]
# Windows Event Log channels to tail
event_log_channels = ["System", "Application", "Security"]

# Extra directories to watch in addition to the auto-discovered ones.
# Standard locations (C:\Windows\Logs, %APPDATA%, %LOCALAPPDATA%,
# %PROGRAMDATA%, %TEMP%) are discovered automatically at startup and
# re-checked every 20 cycles. Add paths here only for non-standard locations.
log_directories = [
    # "D:\\MyApp\\Logs",
]

# How often to poll WMI for system state (CPU, memory, disk, services)
wmi_poll_interval_secs = 300

# How often to check the event log for new entries
event_log_poll_interval_secs = 30

# How often to run a full decision cycle (collect signals → analyse → act).
# Eir only calls the AI model when there's an actionable change, so idle cycles are
# cheap; this interval mainly bounds how often it re-checks. 600s (10 min) keeps
# subscription usage low. Lower it if you want faster reaction to new problems.
decision_interval_secs = 600

# Minimum AI confidence (0.0–1.0) for a whitelisted, reversible fix to
# auto-execute; anything below this is blocked. Lower = more autonomous (acts on
# weaker hunches), higher = more cautious. Editable in the app's Settings panel.
confidence_threshold = 0.80

[persistence]
audit_db = "./eir.db"

# ── Autonomous app updater ────────────────────────────────────────────────────
# Eir can keep your installed apps up to date by itself: it checks for updates,
# applies them with the best method, and — if one fails — reads the actual error
# and tries another way (winget -> Chocolatey -> Scoop -> Microsoft Store -> an
# AI-found official installer). Because the service runs as LocalSystem, this needs
# NO UAC prompt. Everything here is editable in the app's Settings panel.
#
# This whole section is optional: omit it and the defaults below apply (the updater
# stays OFF until you enable it).
[updater]
# Master switch. Off by default — running installers unattended is opt-in.
enabled = false

# How often an unattended update cycle runs (seconds). 86400 = once a day.
schedule_interval_secs = 86400

# Package-manager methods to use, in preference order. Unknown names are ignored.
methods = ["winget", "choco", "scoop", "msstore"]

# Whether AI-found official native installers may be downloaded and run for apps no
# package manager can update.
native_enabled = true

# How strictly a downloaded native installer must be signed before it is allowed to
# run (decided in Rust, never by the AI):
#   "require_valid"            — must have a valid Authenticode signature (default)
#   "require_publisher_match"  — valid AND signer matches the expected publisher
#   "allow_unsigned"           — run regardless of signature (least safe)
native_signature_policy = "require_valid"

# Safety/cost caps.
max_attempts_per_app = 3      # methods tried per app before giving up
max_apps_per_run = 20         # apps acted on per cycle
budget_usd_per_run = 0.50     # AI spend ceiling per cycle (0 = no explicit ceiling)
max_installer_mb = 256        # largest native installer to download

# Auto-install a missing package manager (Chocolatey/Scoop) when a method needs it.
bootstrap_managers = true

# Apps to skip entirely (by stable, version-stripped display name).
ignored = []

# Per-app hints for the AI, e.g. tell it an app is self-built or where its real
# releases live. Keyed by the same stable app name.
# [updater.notes]
# "my custom tool" = "self-built — never report an update"

# ── Advisor mode (AI self-tunes its reasoning) ────────────────────────────────
# When the AI flags a hard/ambiguous situation (or its confidence is low), Eir can
# re-analyse ONCE at a higher reasoning effort and/or a stronger model — cheap/fast
# for routine cycles, deeper only when it matters — bounded by a daily spend cap.
# The escalation tier is fixed config (never AI-chosen); the AI only gets to say
# "I'm not sure, look harder". Off by default. Editable in the app's Settings.
[advisor]
enabled = false

# The stronger model to switch to for the deeper pass (empty = keep the base model).
# e.g. Claude CLI: "opus"; OpenRouter: a paid model id. Effort applies to Claude CLI
# only (other providers have no effort dial — the model switch still works).
escalation_model = ""
escalation_effort = ""              # low|medium|high|xhigh|max (Claude CLI only)

# Escalate when the best reported confidence is below this (0.0–1.0).
low_confidence_threshold = 0.6

# Cap on escalation AI spend per day (USD); 0 = no explicit cap.
budget_usd_per_day = 0.50

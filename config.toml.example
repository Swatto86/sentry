[api]
# ── Option A: Claude CLI (no API key — uses your logged-in `claude` session) ──
# This is the recommended option if you use Claude Code / Claude Max.
# The service runs as LocalSystem. Leave user_profile and claude_cli_path blank
# and it auto-detects: it scans C:\Users for the profile that holds a logged-in
# Claude session (~/.claude/.credentials.json) and finds claude.exe under it.
# Set them explicitly only to override auto-detection.
provider = "claude_cli"
# user_profile = "C:\\Users\\YourName"
# claude_cli_path = "C:\\Users\\YourName\\.local\\bin\\claude.exe"
model = ""   # leave empty to use the CLI's configured default, or set e.g. "claude-opus-4-8"

# Model for the on-demand "Other Updates" app check. This always runs through the
# Claude CLI (it needs live web search), so it must be a Claude model — sonnet,
# haiku, or opus. Free/OpenRouter models can't be used here. Blank = haiku (the
# cheapest). Also editable in the app's Settings panel.
update_check_model = "haiku"

# ── Option B: Anthropic native API ────────────────────────────────────────────
# provider = "anthropic"
# anthropic_api_key = "sk-ant-..."
# model = "claude-opus-4-8"

# ── Option C: OpenRouter (openrouter.ai) — use FREE models, no Claude usage ───
# Lowest-cost option: free models cost nothing and don't touch your Claude plan.
# Free models are slower (30-90s) and a bit less reliable, but fine for a
# background monitor. Pick a current free model from https://openrouter.ai/models
# (filter: free). Good picks: a large free model with solid JSON output.
# All of these are also editable in the app's Settings panel — no need to edit this file.
# provider = "openrouter"
# openrouter_api_key = "sk-or-v1-..."
# model = "nvidia/nemotron-3-super-120b-a12b:free"   # tool-capable; or nemotron-3-ultra-550b:free

# ── Option D: Anthropic native API ────────────────────────────────────────────
# provider = "anthropic"
# anthropic_api_key = "sk-ant-..."
# model = "claude-opus-4-8"

# ── Option E: claude-max-api-proxy (OpenAI-compatible local proxy) ────────────
# Run first: npx claude-max-api-proxy
# provider = "openai_compatible"
# base_url = "http://localhost:3456/v1"
# api_key = "not-needed"
# model = "claude-opus-4-8"

[monitoring]
# Windows Event Log channels to tail
event_log_channels = ["System", "Application", "Security"]

# Extra directories to watch in addition to the auto-discovered ones.
# Standard locations (C:\Windows\Logs, %APPDATA%, %LOCALAPPDATA%,
# %PROGRAMDATA%, %TEMP%) are discovered automatically at startup and
# re-checked every 20 cycles. Add paths here only for non-standard locations.
log_directories = [
    # "D:\\MyApp\\Logs",
]

# How often to poll WMI for system state (CPU, memory, disk, services)
wmi_poll_interval_secs = 300

# How often to check the event log for new entries
event_log_poll_interval_secs = 30

# How often to run a full decision cycle (collect signals → analyse → act).
# Sentry only calls Claude when there's an actionable change, so idle cycles are
# cheap; this interval mainly bounds how often it re-checks. 600s (10 min) keeps
# subscription usage low. Lower it if you want faster reaction to new problems.
decision_interval_secs = 600

[persistence]
audit_db = "./sentry.db"

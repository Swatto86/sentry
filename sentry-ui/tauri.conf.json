{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Sentry",
  "version": "0.4.0",
  "identifier": "co.swatto.sentry",
  "build": {
    "frontendDist": "../ui",
    "beforeBuildCommand": "cargo build -p sentry-svc --release",
    "beforeDevCommand": ""
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Sentry — System Monitor",
        "width": 1000,
        "height": 680,
        "visible": false,
        "center": true,
        "resizable": true,
        "decorations": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "../icons/32x32.png",
      "../icons/128x128.png",
      "../icons/128x128@2x.png",
      "../icons/icon.ico"
    ],
    "publisher": "Swatto",
    "copyright": "© 2026 Swatto",
    "category": "Utility",
    "shortDescription": "Autonomous Windows system repair agent",
    "longDescription": "Sentry monitors Windows system health and autonomously diagnoses and repairs problems — service failures, disk pressure, log corruption, driver issues, and more — using Claude AI as its reasoning engine.",
    "windows": {
      "allowDowngrades": false,
      "nsis": {
        "installMode": "perMachine",
        "languages": ["English"],
        "displayLanguageSelector": false
      }
    }
  }
}

{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Sentry",
  "version": "0.5.27",
  "identifier": "co.swatto.sentry",
  "build": {
    "frontendDist": "../ui",
    "beforeBuildCommand": "powershell -NoProfile -ExecutionPolicy Bypass -File sentry-ui\\build-svc.ps1",
    "beforeDevCommand": ""
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Sentry — System Monitor",
        "width": 1000,
        "height": 680,
        "visible": false,
        "center": true,
        "resizable": true,
        "decorations": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline'"
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDRDNTExNDdGRERGMjI4RDMKUldUVEtQTGRmeFJSVElqYUlJRU1ENzZDZ1dCZDg3ZFpHZnllUGZKQXZHdGZJTzRURjAweXArT2oK",
      "endpoints": [
        "https://github.com/Swatto86/sentry/releases/latest/download/latest.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "createUpdaterArtifacts": true,
    "icon": [
      "../icons/32x32.png",
      "../icons/128x128.png",
      "../icons/128x128@2x.png",
      "../icons/icon.ico"
    ],
    "publisher": "Swatto",
    "copyright": "© 2026 Swatto",
    "category": "Utility",
    "shortDescription": "Autonomous Windows system repair agent",
    "longDescription": "Sentry monitors Windows system health and autonomously diagnoses and repairs problems — service failures, disk pressure, log corruption, driver issues, and more — using Claude AI as its reasoning engine.",
    "resources": {
      "bin/sentry-svc.exe": "sentry-svc.exe",
      "../config.toml.example": "config.toml.example",
      "../policy.toml": "policy.toml"
    },
    "windows": {
      "allowDowngrades": false,
      "nsis": {
        "installMode": "perMachine",
        "installerHooks": "installer-hooks.nsh",
        "languages": ["English"],
        "displayLanguageSelector": false
      }
    }
  }
}

{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Sentry",
  "version": "0.4.0",
  "identifier": "co.swatto.sentry",
  "build": {
    "frontendDist": "ui",
    "beforeBuildCommand": "",
    "beforeDevCommand": ""
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Sentry — System Monitor",
        "width": 1000,
        "height": 680,
        "visible": false,
        "center": true,
        "resizable": true,
        "decorations": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": false,
    "icon": []
  }
}
